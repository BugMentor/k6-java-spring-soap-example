{
  "uid": "payment-service-monitor",
  "title": "Payment Service - Real-Time Monitoring",
  "description": "Production monitoring dashboard for Java SOAP Payment Service. CPU, memory, JVM, DB pool, request latency, throughput, and error rates.",
  "tags": [
    "payment",
    "java",
    "soap",
    "monitoring"
  ],
  "timezone": "browser",
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "custom",
        "current": {
          "text": "payments",
          "value": "payments"
        },
        "options": [
          {
            "text": "payments",
            "value": "payments"
          }
        ],
        "multi": false,
        "includeAll": false
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PAE45454D0EDB9216"
        },
        "query": "label_values(up{app=\"payment-service\"}, instance)",
        "multi": true,
        "includeAll": true,
        "refresh": 2
      }
    ]
  },
  "rows": [
    {
      "title": "Auto-Scaling (HPA)",
      "collapse": false,
      "panels": [
        {
          "title": "Pod Count (HPA Scaling)",
          "type": "timeseries",
          "gridPos": {
            "x": 0,
            "y": 0,
            "w": 8,
            "h": 8
          },
          "targets": [
            {
              "expr": "count(up{app=\"payment-service\"})",
              "legendFormat": "Running Pods",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 5
                  },
                  {
                    "color": "red",
                    "value": 15
                  }
                ]
              }
            }
          }
        },
        {
          "title": "Process CPU Usage (Aggregate)",
          "type": "timeseries",
          "gridPos": {
            "x": 8,
            "y": 0,
            "w": 8,
            "h": 8
          },
          "targets": [
            {
              "expr": "process_cpu_usage{app=\"payment-service\"} * 100",
              "legendFormat": "CPU %",
              "refId": "A"
            },
            {
              "expr": "80",
              "legendFormat": "HPA Target (80%)",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 60
                  },
                  {
                    "color": "red",
                    "value": 80
                  }
                ]
              }
            }
          }
        },
        {
          "title": "JVM Heap Memory (Aggregate)",
          "type": "timeseries",
          "gridPos": {
            "x": 16,
            "y": 0,
            "w": 8,
            "h": 8
          },
          "targets": [
            {
              "expr": "jvm_memory_used_bytes{app=\"payment-service\",area=\"heap\"} / jvm_memory_max_bytes{app=\"payment-service\",area=\"heap\"} * 100",
              "legendFormat": "Heap %",
              "refId": "A"
            },
            {
              "expr": "60",
              "legendFormat": "HPA Target (60%)",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 40
                  },
                  {
                    "color": "red",
                    "value": 60
                  }
                ]
              }
            }
          }
        }
      ]
    },
    {
      "title": "Resource Consumption",
      "collapse": false,
      "panels": [
        {
          "title": "CPU Usage",
          "type": "timeseries",
          "gridPos": {
            "x": 0,
            "y": 0,
            "w": 12,
            "h": 8
          },
          "targets": [
            {
              "expr": "process_cpu_usage{app=\"payment-service\"} * 100",
              "legendFormat": "Process CPU %",
              "refId": "A"
            },
            {
              "expr": "system_cpu_usage * 100",
              "legendFormat": "System CPU %",
              "refId": "B"
            },
            {
              "expr": "80",
              "legendFormat": "HPA CPU Threshold (80%)",
              "refId": "C"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 60
                  },
                  {
                    "color": "red",
                    "value": 80
                  }
                ]
              }
            }
          }
        },
        {
          "title": "JVM Heap Memory %",
          "type": "timeseries",
          "gridPos": {
            "x": 12,
            "y": 0,
            "w": 12,
            "h": 8
          },
          "targets": [
            {
              "expr": "jvm_memory_used_bytes{app=\"payment-service\",area=\"heap\"} / jvm_memory_max_bytes{app=\"payment-service\",area=\"heap\"} * 100",
              "legendFormat": "{{pod}} - Heap %",
              "refId": "A"
            },
            {
              "expr": "60",
              "legendFormat": "Memory Threshold (60%)",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 40
                  },
                  {
                    "color": "red",
                    "value": 60
                  }
                ]
              }
            }
          }
        },
        {
          "title": "Active Requests & DB Connections",
          "type": "timeseries",
          "gridPos": {
            "x": 0,
            "y": 8,
            "w": 12,
            "h": 8
          },
          "targets": [
            {
              "expr": "http_server_requests_active_seconds_active_count{app=\"payment-service\"}",
              "legendFormat": "Active HTTP Requests",
              "refId": "A"
            },
            {
              "expr": "hikaricp_connections_active{app=\"payment-service\"}",
              "legendFormat": "Active DB Connections",
              "refId": "B"
            },
            {
              "expr": "hikaricp_connections_pending{app=\"payment-service\"}",
              "legendFormat": "Pending DB Connections",
              "refId": "C"
            },
            {
              "expr": "tomcat_sessions_active_current_sessions{app=\"payment-service\"}",
              "legendFormat": "Active Tomcat Sessions",
              "refId": "D"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0
            }
          }
        },
        {
          "title": "Request Rate by Endpoint",
          "type": "timeseries",
          "gridPos": {
            "x": 12,
            "y": 8,
            "w": 12,
            "h": 8
          },
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_seconds_count{app=\"payment-service\",uri!=\"/actuator/prometheus\"}[1m])) by (uri)",
              "legendFormat": "{{uri}} - RPS",
              "refId": "A"
            },
            {
              "expr": "sum(rate(http_server_requests_seconds_count{app=\"payment-service\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{app=\"payment-service\"}[1m])) * 100",
              "legendFormat": "Error %",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        }
      ]
    },
    {
